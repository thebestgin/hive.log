ASPNETCORE_ENVIRONMENT=Development

# Database connection string (PostgreSQL / TimescaleDB)
# In Docker: uses internal service name 'postgres-dev' on port 5432
# Local dev: change host to 'localhost'
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hivelog;Username=jobdate;Password=jobdate123

# API Key for authenticating ingest and query requests
# All callers (backend services, agents, frontend) must include:
# X-Api-Key: <value>
HiveLog__ApiKey=dev-hivelog-key-change-in-production

# Retention policies (days) — all optional, defaults shown
# HiveLog__RetentionDays=30          # TimescaleDB chunk retention (drop chunks older than N days)
# HiveLog__AuditRetentionDays=365    # Audit stream retention (stream = 'audit')
# HiveLog__DebugTraceRetentionDays=7 # Fine-grained: delete Debug/Trace entries older than N days
# HiveLog__InfoRetentionDays=30      # Fine-grained: delete Info entries older than N days

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
AllowedHosts=*
