ASPNETCORE_ENVIRONMENT=Development

# Database connection string (PostgreSQL / TimescaleDB)
# In Docker: uses internal service name 'postgres-dev' on port 5432
# Local dev: change host to 'localhost'
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=hivelog;Username=jobdate;Password=jobdate123

# API Key for admin endpoints (/admin/flush, /admin/stats, /admin/retention)
# HiveLog__ApiKey is still used by AdminApiKeyFilter for query endpoints.
# Connector auth is fully manifest-driven — per-service keys live in hivelog-manifest.json.
HiveLog__ApiKey=dev-hivelog-key-change-in-production

# Manifest path — points to the hivelog-manifest.json file.
# Dev default: relative path to the checked-in dev manifest.
# Docker/Prod: absolute path to the mounted manifest file.
HiveLogManifest__FilePath=_Projects/Manifests/JobDate/hivelog-manifest.json

# Admin API Key for admin endpoints (/admin/flush, /admin/stats, /admin/retention)
# Must be included as Admin-Api-Key header. Different from HiveLog__ApiKey.
HiveLog__AdminApiKey=dev-admin-key-change-in-production

# Retention policies (days) — all optional, defaults shown
# HiveLog__RetentionDays=30          # TimescaleDB chunk retention (drop chunks older than N days)
# HiveLog__AuditRetentionDays=365    # Audit stream retention (stream = 'audit')
# HiveLog__DebugTraceRetentionDays=7 # Fine-grained: delete Debug/Trace entries older than N days
# HiveLog__InfoRetentionDays=30      # Fine-grained: delete Info entries older than N days

# NL-to-SQL — Stufe 2: OpenAI Chat Completions fallback (optional)
# When Enabled=false, only the template-matcher (Stufe 1) is used.
# Admin-only feature: ~3-4 calls/day, quality over speed.
HiveLog__NlQuery__Enabled=true
HiveLog__NlQuery__ApiKey=<your-openai-api-key>
HiveLog__NlQuery__Model=gpt-4.1
# HiveLog__NlQuery__BaseUrl=https://api.openai.com  # optional, default shown
# HiveLog__NlQuery__TimeoutSeconds=30               # optional, default shown

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
AllowedHosts=*

# JWT Bearer Authentication — optional, nur für WebApp Connector
# Wenn gesetzt: Bearer Token wird validiert; User.Identity.IsAuthenticated = true bei gültigem Token
# Gleiche Keycloak-Instanz wie alle anderen JobDate-Services
JwtBearer__Authority=http://localhost:3300/iam/realms/jobdate
JwtBearer__Audience=hive.log
